# ===============================================
# CTU-Connect Environment Variables (Team Template)
# ===============================================
# Copy this file to .env and update secrets before running.
# Do not commit .env to source control.
# ===============================================

# ==================== Host Port Mapping (Docker -> Host) ====================
# Use 18xxx to avoid conflicts with services running directly on localhost.
EUREKA_PORT=18761
API_GATEWAY_PORT=18090
PROMETHEUS_PORT=19090
AUTH_SERVICE_PORT=18080
USER_SERVICE_PORT=18081
MEDIA_SERVICE_PORT=18084
POST_SERVICE_PORT=18085
CHAT_SERVICE_PORT=18086
RECOMMEND_SERVICE_PORT=18095

# ==================== Shared Security/Auth ====================
# Generate a secure key: openssl rand -base64 32
JWT_SECRET=change_this_secret_in_production
JWT_EXPIRATION=86400000
JWT_REFRESH_EXPIRATION=604800000

# ==================== Core Databases ====================
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change_postgres_password

NEO4J_USER=neo4j
NEO4J_PASSWORD=password

# Neo4j Docker image expects NEO4J_AUTH=user/password (set via compose from NEO4J_USER + NEO4J_PASSWORD)

# ==================== Recommendation Service (isolated DB/Redis) ====================
RECOMMEND_DB_NAME=recommend_db
RECOMMEND_DB_USER=recommend_user
RECOMMEND_DB_PASSWORD=change_recommend_db_password
RECOMMEND_REDIS_PASSWORD=change_recommend_redis_password

# ==================== Email (Auth Service) ====================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USERNAME=your_email@gmail.com
MAIL_PASSWORD=your_gmail_app_password

# ==================== Media Storage (Media Service) ====================
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# ==================== Frontend Local Config ====================
NEXT_PUBLIC_API_URL=http://localhost:18090
NEXT_PUBLIC_WS_URL=ws://localhost:18090/api/ws/chat

# ==================== Optional/Legacy ====================
SPRING_PROFILES_ACTIVE=docker
RECAPTCHA_SITE_KEY=
RECAPTCHA_SECRET_KEY=
